BACKEND_PORT=3333
BACKEND_HOST=0.0.0.0

# CORS — adicione os IPs da sua rede local conforme necessário
CORS_ORIGINS=http://localhost:5180,http://127.0.0.1:5180

LOG_LEVEL=info
DATABASE_PATH=database/sara_core.db

# STT — sobrescreva com paths absolutos no .env local se necessário
STT_PROVIDER=vosk
STT_MODEL_PATH=services/stt/models/pt-br
STT_AUDIO_MAX_BYTES=10485760
STT_FFMPEG_PATH=ffmpeg
STT_PYTHON_PATH=python
