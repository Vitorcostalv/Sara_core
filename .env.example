# Runtime
NODE_ENV=development
LOG_LEVEL=info

# Backend
BACKEND_PORT=3333
BACKEND_HOST=0.0.0.0

# CORS — separar por vírgula, sem espaços
CORS_ORIGINS=http://localhost:5180,http://127.0.0.1:5180,http://192.168.0.85:5180,http://10.147.19.63:5180

# STT
STT_PROVIDER=vosk
STT_MODEL_PATH=services/stt/models/pt-br
STT_AUDIO_MAX_BYTES=10485760
STT_FFMPEG_PATH=ffmpeg
STT_PYTHON_PATH=python

# Database — Neon PostgreSQL
# DATABASE_PROVIDER=postgres (documentação; não é lido pelo código — apenas pg é suportado)
DATABASE_PROVIDER=postgres
# Use o host pooler (com -pooler) para a aplicação em runtime
DATABASE_URL=postgresql://neondb_owner:<SENHA>@<HOST-POOLER>/neondb?sslmode=require
# Use o host direto (sem -pooler) para migrations, reset e seed
DIRECT_DATABASE_URL=postgresql://neondb_owner:<SENHA>@<HOST-DIRECT>/neondb?sslmode=require
DATABASE_SSL=true

# LLM
LLM_PROVIDER=disabled
LLM_API_KEY=
LLM_MODEL=
LLM_BASE_URL=
LLM_TIMEOUT_MS=45000

# Frontend (Vite)
VITE_API_BASE_URL=http://localhost:3333/api/v1
