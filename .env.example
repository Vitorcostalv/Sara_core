# Runtime
NODE_ENV=development
LOG_LEVEL=info

# Backend
BACKEND_PORT=3333
BACKEND_HOST=0.0.0.0
API_JSON_MAX_BYTES=262144
AUTH_MODE=disabled
API_AUTH_KEY=
TRUST_PROXY=false
VOICE_RATE_LIMIT_WINDOW_MS=60000
VOICE_RATE_LIMIT_MAX=10
LLM_RATE_LIMIT_WINDOW_MS=60000
LLM_RATE_LIMIT_MAX=20

# CORS - comma-separated, no spaces
CORS_ORIGINS=http://localhost:5180,http://127.0.0.1:5180,http://192.168.0.85:5180,http://10.147.19.63:5180

# STT
STT_PROVIDER=vosk
STT_MODEL_PATH=services/stt/models/pt-br
STT_AUDIO_MAX_BYTES=10485760
STT_FFMPEG_PATH=ffmpeg
STT_PYTHON_PATH=python

# Database - Neon PostgreSQL
# DATABASE_PROVIDER is documentation-only. The runtime uses pg directly.
DATABASE_PROVIDER=postgres
# Use the pooler host (with -pooler) for application runtime
DATABASE_URL=postgresql://neondb_owner:<PASSWORD>@<POOLER-HOST>/neondb
# Use the direct host (without -pooler) for migrations, reset and seed
DIRECT_DATABASE_URL=postgresql://neondb_owner:<PASSWORD>@<DIRECT-HOST>/neondb
DATABASE_SSL=true
DATABASE_SSL_MODE=verify-full

# LLM
LLM_PROVIDER=disabled
LLM_API_KEY=
LLM_MODEL=
LLM_BASE_URL=
LLM_TIMEOUT_MS=45000

# Frontend (Vite)
VITE_API_BASE_URL=http://localhost:3333/api/v1
