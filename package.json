{
  "name": "sara-core",
  "version": "0.1.0",
  "private": true,
  "description": "Sara Core monorepo foundation for a local/offline personal assistant.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n backend,frontend -c cyan,magenta \"npm run dev -w @sara/backend\" \"npm run dev -w @sara/frontend\"",
    "dev:backend": "npm run dev -w @sara/backend",
    "dev:frontend": "npm run dev -w @sara/frontend",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test -w @sara/backend",
    "test:e2e": "npm run test:e2e -w @sara/frontend",
    "db:check": "npm run db:check -w @sara/backend",
    "db:migrate": "npm run db:migrate -w @sara/backend",
    "db:reset": "npm run db:reset -w @sara/backend",
    "db:seed": "npm run db:seed -w @sara/backend"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "concurrently": "^9.1.2",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.59.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
